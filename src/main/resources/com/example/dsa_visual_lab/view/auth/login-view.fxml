<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="800.0" prefWidth="1280.0"
           style="-fx-background-color: #0F172A;"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.dsa_visual_lab.controller.auth.LoginController">

    <VBox alignment="CENTER" spacing="20.0" maxWidth="400.0" maxHeight="450.0"
          style="-fx-background-color: #1E293B; -fx-background-radius: 12; -fx-border-color: #38BDF8; -fx-border-radius: 12; -fx-border-width: 2;">

        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <Label text="DSA VISUAL LAB" textFill="#38BDF8">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label text="Login to continue" textFill="#94A3B8">
            <font>
                <Font name="System Italic" size="14.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" top="-15.0"/>
            </VBox.margin>
        </Label>

        <Label fx:id="statusLabel" textFill="#F87171" wrapText="true" textAlignment="CENTER" />

        <TextField fx:id="usernameField" promptText="Username" prefHeight="40.0"
                   style="-fx-background-color: #0F172A; -fx-text-fill: white; -fx-border-color: #38BDF8; -fx-border-radius: 5; -fx-background-radius: 5; -fx-prompt-text-fill: #64748B; -fx-padding: 10;"/>

        <PasswordField fx:id="passwordField" promptText="Password" prefHeight="40.0"
                       style="-fx-background-color: #0F172A; -fx-text-fill: white; -fx-border-color: #38BDF8; -fx-border-radius: 5; -fx-background-radius: 5; -fx-prompt-text-fill: #64748B; -fx-padding: 10;"/>

        <Button text="Login" onAction="#handleLoginClick" prefHeight="40.0" maxWidth="Infinity"
                style="-fx-background-color: #38BDF8; -fx-text-fill: #0F172A; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand;"/>

        <Button text="Create New Account" onAction="#handleRegisterClick" prefHeight="40.0" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #818CF8; -fx-border-color: #818CF8; -fx-border-radius: 5; -fx-cursor: hand;"/>

    </VBox>
</StackPane>