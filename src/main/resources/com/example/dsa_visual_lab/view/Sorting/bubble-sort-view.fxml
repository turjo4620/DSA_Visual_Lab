<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dsa_visual_lab.controller.sorting.BubbleSortController"
      spacing="20"
      style="-fx-background-color: #0f172a; -fx-padding: 20;">

    <!-- Back Button -->
    <HBox alignment="TOP_LEFT">
        <Button text="← BACK"
                prefWidth="120"
                prefHeight="40"
                onAction="#handleBack"
                styleClass="algo-button"
                style="-fx-border-color: #F87171;"/>
    </HBox>

    <!-- Main Content -->
    <HBox spacing="30">

        <!-- LEFT: Visualization -->
        <StackPane alignment="CENTER">
            <Pane fx:id="visualizationPane"
                  prefWidth="600"
                  prefHeight="350"
                  style="-fx-background-color: linear-gradient(to bottom, #111827, #1E293B);
             -fx-background-radius: 20;
             -fx-border-color: #374151;
             -fx-border-radius: 20;
             -fx-border-width: 2;"/>
        </StackPane>

        <!-- RIGHT: Pseudocode Section -->
        <VBox spacing="15" prefWidth="350">

            <!-- Title -->
            <Label text="Pseudocode"
                   style="-fx-text-fill: #FACC15; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <!-- Rectangular Code Box -->
            <VBox spacing="10"
                  style="-fx-background-color: #111827;
                         -fx-border-color: #374151;
                         -fx-border-width: 2;
                         -fx-background-radius: 10;
                         -fx-border-radius: 10;
                         -fx-padding: 20;">

                <Label fx:id="line1"
                       text="for i = 0 to n-1"
                       style="-fx-text-fill: white; -fx-font-size: 14px;"/>

                <Label fx:id="line2"
                       text="   for j = 0 to n-i-1"
                       style="-fx-text-fill: white; -fx-font-size: 14px;"/>

                <Label fx:id="line3"
                       text="      if arr[j] > arr[j+1]"
                       style="-fx-text-fill: white; -fx-font-size: 14px;"/>

                <Label fx:id="line4"
                       text="         swap(arr[j], arr[j+1])"
                       style="-fx-text-fill: white; -fx-font-size: 14px;"/>

            </VBox>

        </VBox>

    </HBox>

    <!-- Buttons -->
    <HBox spacing="20" alignment="CENTER">
        <Button text="Start"
                onAction="#startSort"
                prefWidth="200"
                prefHeight="50"
                styleClass="algo-button"
                style="-fx-border-color: #FB923C;"/>

        <Button text="Reset"
                onAction="#resetArray"
                prefWidth="200"
                prefHeight="50"
                styleClass="algo-button"
                style="-fx-border-color: #FB923C;"/>
    </HBox>

</VBox>