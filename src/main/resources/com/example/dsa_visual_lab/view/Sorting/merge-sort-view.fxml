<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dsa_visual_lab.controller.sorting.MergeSortController"
      spacing="20"
      style="-fx-background-color: #0f172a; -fx-padding: 20;">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="← BACK"
                prefWidth="120"
                prefHeight="40"
                onAction="#handleBack"
                styleClass="algo-button"
                style="-fx-border-color: #F87171; -fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
        <Label text="Merge Sort" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="30" VBox.vgrow="ALWAYS">
        <StackPane alignment="CENTER" HBox.hgrow="ALWAYS">
            <clip>
                <Rectangle width="850" height="750"/>
            </clip>

            <HBox fx:id="arrayContainer"
                  alignment="TOP_CENTER"
                  fillHeight="false"
                  spacing="5"
                  prefWidth="850"
                  prefHeight="750"
                  maxWidth="Infinity"
                  maxHeight="Infinity"
                  style="-fx-background-color: #111827;
                         -fx-background-radius: 20;
                         -fx-border-color: #374151;
                         -fx-border-radius: 20;
                         -fx-border-width: 2;
                         -fx-padding: 20;"/>
        </StackPane>

        <VBox spacing="15" prefWidth="400">
            <Label text="Pseudocode" style="-fx-text-fill: #FACC15; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <VBox spacing="8" style="-fx-background-color: #111827; -fx-border-color: #374151; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 20;">
                <Label fx:id="line1" text="mergeSort(arr, l, r)" style="-fx-text-fill: white;"/>
                <Label fx:id="line2" text="  if l &lt; r" style="-fx-text-fill: white;"/>
                <Label fx:id="line3" text="    mid = l + (r - l) / 2" style="-fx-text-fill: white;"/>
                <Label fx:id="line4" text="    mergeSort(arr, l, mid)" style="-fx-text-fill: white;"/>
                <Label fx:id="line5" text="    mergeSort(arr, mid + 1, r)" style="-fx-text-fill: white;"/>
                <Label fx:id="line6" text="    merge(arr, l, mid, r)" style="-fx-text-fill: white;"/>
                <Label fx:id="line7" text=""/>
                <Label fx:id="line8" text="merge(arr, l, mid, r)" style="-fx-text-fill: white;"/>
                <Label fx:id="line9" text="  copy to temp arrays L[] and R[]" style="-fx-text-fill: white;"/>
                <Label fx:id="line10" text="  while L and R have elements:" style="-fx-text-fill: white;"/>
                <Label fx:id="line11" text="    arr[k] = smaller(L[i], R[j])" style="-fx-text-fill: white;"/>
                <Label fx:id="line12" text="  copy remaining elements" style="-fx-text-fill: white;"/>
            </VBox>

            <Label fx:id="statusLabel" text="Enter array values and click Set Array" style="-fx-text-fill: #38BDF8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-wrap-text: true;"/>
        </VBox>
    </HBox>

    <HBox fx:id="controlsBox" spacing="15" alignment="CENTER" style="-fx-padding: 10;">
        <TextField fx:id="inputField" promptText="Enter numbers (e.g. 5, 3, 8)" prefWidth="250" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-border-color: #374151;"/>

        <Button text="Set Array" onAction="#handleSetArray" style="-fx-background-color: #60A5FA; -fx-text-fill: black;"/>

        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #1E293B; -fx-padding: 5 10; -fx-border-radius: 5; -fx-border-color: #475569;">
            <Label text="Speed" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
            <Slider fx:id="speedSlider" min="10" max="200" value="100" prefWidth="100"/>
        </VBox>

        <Button text="Start" onAction="#handleStart" prefWidth="150" style="-fx-background-color: #34D399; -fx-text-fill: #0F172A;"/>

        <Button text="Reset" onAction="#handleReset" prefWidth="120" style="-fx-background-color: transparent; -fx-text-fill: #FB923C; -fx-border-color: #FB923C;"/>
    </HBox>
</VBox>