<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dsa_visual_lab.controller.sorting.MergeSortController"
      stylesheets="@../styles/sorting/merge.css"
      styleClass="sorting-root"
      spacing="20">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="← BACK"
                prefWidth="120"
                prefHeight="40"
                onAction="#handleBack"
                styleClass="back-button"/>
        <Label text="Merge Sort" styleClass="title-label"/>
    </HBox>

    <HBox spacing="30" VBox.vgrow="ALWAYS">
        <StackPane alignment="CENTER" HBox.hgrow="ALWAYS">
            <clip>
                <Rectangle width="850" height="750"/>
            </clip>

            <HBox fx:id="arrayContainer"
                  styleClass="array-container"
                  alignment="TOP_CENTER"
                  fillHeight="false"
                  spacing="5"
                  prefWidth="850"
                  prefHeight="750"
                  maxWidth="Infinity"
                  maxHeight="Infinity"/>
        </StackPane>

        <VBox spacing="15" prefWidth="400">
            <Label text="Pseudocode" styleClass="section-title"/>

            <VBox styleClass="pseudocode-box" spacing="8">
                <Label fx:id="line1" text="mergeSort(arr, l, r)" styleClass="pseudocode-line"/>
                <Label fx:id="line2" text="  if l &lt; r" styleClass="pseudocode-line"/>
                <Label fx:id="line3" text="    mid = l + (r - l) / 2" styleClass="pseudocode-line"/>
                <Label fx:id="line4" text="    mergeSort(arr, l, mid)" styleClass="pseudocode-line"/>
                <Label fx:id="line5" text="    mergeSort(arr, mid + 1, r)" styleClass="pseudocode-line"/>
                <Label fx:id="line6" text="    merge(arr, l, mid, r)" styleClass="pseudocode-line"/>
                <Label fx:id="line7" text="" styleClass="pseudocode-line"/>
                <Label fx:id="line8" text="merge(arr, l, mid, r)" styleClass="pseudocode-line"/>
                <Label fx:id="line9" text="  copy to temp arrays L[] and R[]" styleClass="pseudocode-line"/>
                <Label fx:id="line10" text="  while L and R have elements:" styleClass="pseudocode-line"/>
                <Label fx:id="line11" text="    arr[k] = smaller(L[i], R[j])" styleClass="pseudocode-line"/>
                <Label fx:id="line12" text="  copy remaining elements" styleClass="pseudocode-line"/>
            </VBox>

            <Label fx:id="statusLabel" text="Enter array values and click Set Array" styleClass="status-label"/>
        </VBox>
    </HBox>

    <HBox fx:id="controlsBox" styleClass="controls-box" spacing="15" alignment="CENTER">
        <TextField fx:id="inputField" promptText="Enter numbers (e.g. 5, 3, 8)" prefWidth="250" styleClass="array-input"/>

        <Button text="Set Array" onAction="#handleSetArray" styleClass="secondary-btn" id="set-btn"/>

        <VBox alignment="CENTER" spacing="5" styleClass="speed-box">
            <Label text="Speed" styleClass="speed-label"/>
            <Slider fx:id="speedSlider" min="10" max="200" value="100" prefWidth="100"/>
        </VBox>

        <Button text="Start Sort" onAction="#handleStart" prefWidth="150" styleClass="primary-btn"/>
        <Button text="Reset" onAction="#handleReset" prefWidth="120" styleClass="secondary-btn" id="reset-btn"/>
    </HBox>
</VBox>