<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dsa_visual_lab.controller.sorting.QuickSortController"
      stylesheets="@../styles/sorting/quick.css"
      styleClass="sorting-root"
      spacing="20">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="← BACK" prefWidth="120" prefHeight="40" onAction="#handleBack" styleClass="back-button"/>
        <Label text="Quick Sort" styleClass="title-label"/>
    </HBox>

    <VBox spacing="15" VBox.vgrow="ALWAYS">
        <HBox spacing="30" HBox.hgrow="ALWAYS">
            <StackPane alignment="CENTER" HBox.hgrow="ALWAYS">
                <HBox fx:id="arrayContainer" styleClass="array-container" alignment="BOTTOM_CENTER" fillHeight="false" spacing="5" prefWidth="850" prefHeight="750" maxWidth="Infinity" maxHeight="Infinity"/>
            </StackPane>

            <VBox spacing="15" prefWidth="400">
                <Label text="Pseudocode" styleClass="section-title"/>
                <VBox spacing="8" styleClass="pseudocode-box">
                    <Label fx:id="line1" text="quicksort(arr, low, high)" styleClass="pseudocode-line"/>
                    <Label fx:id="line2" text="   if low &lt; high" styleClass="pseudocode-line"/>
                    <Label fx:id="line3" text="      pi = partition(arr, low, high)" styleClass="pseudocode-line"/>
                    <Label fx:id="line4" text="      quicksort(arr, low, pi - 1)" styleClass="pseudocode-line"/>
                    <Label fx:id="line5" text="      quicksort(arr, pi + 1, high)" styleClass="pseudocode-line"/>
                    <Label fx:id="line6" text="partition(arr, low, high)" styleClass="pseudocode-line"/>
                    <Label fx:id="line7" text="   pivot = arr[high]" styleClass="pseudocode-line"/>
                    <Label fx:id="line8" text="   i = low - 1" styleClass="pseudocode-line"/>
                    <Label fx:id="line9" text="   for j = low to high - 1" styleClass="pseudocode-line"/>
                    <Label fx:id="line10" text="      if arr[j] &lt; pivot" styleClass="pseudocode-line"/>
                    <Label fx:id="line11" text="         i++ ; swap(arr[i], arr[j])" styleClass="pseudocode-line"/>
                    <Label fx:id="line12" text="   swap(arr[i+1], arr[high]); return i+1" styleClass="pseudocode-line"/>
                </VBox>
                <Label fx:id="statusLabel" text="Enter array values and click Set Array" styleClass="status-label"/>
            </VBox>
        </HBox>

        <HBox fx:id="controlsBox" spacing="15" alignment="CENTER" styleClass="controls-box">
            <TextField fx:id="inputField" promptText="e.g. 50, 20, 80, 10, 30" prefWidth="250" styleClass="array-input"/>
            <Button text="Set Array" onAction="#handleSetArray" prefWidth="120" styleClass="secondary-btn" id="set-btn"/>
            <VBox alignment="CENTER" spacing="5" styleClass="speed-box">
                <Label text="Speed" styleClass="speed-label"/>
                <Slider fx:id="speedSlider" min="10" max="200" value="100" prefWidth="100"/>
            </VBox>
            <Button text="Start Sort" onAction="#handleStart" prefWidth="150" styleClass="primary-btn"/>
            <Button text="Reset" onAction="#handleReset" prefWidth="120" styleClass="secondary-btn" id="reset-btn"/>
        </HBox>
    </VBox>
</VBox>