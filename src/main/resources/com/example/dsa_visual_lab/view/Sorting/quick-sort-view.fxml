<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dsa_visual_lab.controller.sorting.QuickSortController"
      spacing="20"
      style="-fx-background-color: #0f172a; -fx-padding: 20;">

    <HBox alignment="TOP_LEFT">
        <Button text="← BACK"
                prefWidth="120"
                prefHeight="40"
                onAction="#handleBack"
                styleClass="algo-button"
                style="-fx-border-color: #F87171; -fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>

    <HBox spacing="30" VBox.vgrow="ALWAYS">
        <StackPane alignment="CENTER" HBox.hgrow="ALWAYS">
            <HBox fx:id="arrayContainer"
                  alignment="BOTTOM_CENTER"
                  fillHeight="false"
                  spacing="5"
                  prefWidth="850"
                  prefHeight="750"
                  maxWidth="Infinity"
                  maxHeight="Infinity"
                  style="-fx-background-color: linear-gradient(to bottom, #111827, #1E293B); -fx-background-radius: 20; -fx-border-color: #374151; -fx-border-radius: 20; -fx-border-width: 2; -fx-padding: 20;"/>
        </StackPane>

        <VBox spacing="15" prefWidth="400">
            <Label text="Pseudocode" style="-fx-text-fill: #FACC15; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <VBox spacing="8" style="-fx-background-color: #111827; -fx-border-color: #374151; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 20;">
                <Label fx:id="line1" text="quicksort(arr, low, high)" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line2" text="   if low &lt; high" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line3" text="      pi = partition(arr, low, high)" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line4" text="      quicksort(arr, low, pi - 1)" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line5" text="      quicksort(arr, pi + 1, high)" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line6" text="partition(arr, low, high)" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line7" text="   pivot = arr[high]" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line8" text="   i = low - 1" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line9" text="   for j = low to high - 1" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line10" text="      if arr[j] &lt; pivot" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line11" text="         i++ ; swap(arr[i], arr[j])" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label fx:id="line12" text="   swap(arr[i+1], arr[high]); return i+1" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            </VBox>
            <Label fx:id="statusLabel" text="Enter array values and click Set Array" style="-fx-text-fill: #38BDF8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-wrap-text: true;"/>
        </VBox>
    </HBox>

    <HBox fx:id="controlsBox" spacing="15" alignment="CENTER" style="-fx-padding: 10;">
        <TextField fx:id="inputField" promptText="e.g. 50, 20, 80, 10, 30" prefWidth="250" style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-border-color: #475569; -fx-padding: 10; -fx-background-radius: 5;"/>
        <Button text="Set Array" onAction="#handleSetArray" prefWidth="120" style="-fx-background-color: transparent; -fx-text-fill: #38BDF8; -fx-border-color: #38BDF8; -fx-cursor: hand; -fx-padding: 10; -fx-border-radius: 5;"/>

        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #1E293B; -fx-padding: 5 15; -fx-border-radius: 5; -fx-border-color: #475569;">
            <Label text="Speed" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
            <Slider fx:id="speedSlider" min="10" max="200" value="100" prefWidth="100"/>
        </VBox>

        <Button text="Start Sort" onAction="#handleStart" prefWidth="150" style="-fx-background-color: #34D399; -fx-text-fill: #0F172A; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10; -fx-background-radius: 5;"/>
        <Button text="Reset" onAction="#handleReset" prefWidth="120" style="-fx-background-color: transparent; -fx-text-fill: #FB923C; -fx-border-color: #FB923C; -fx-cursor: hand; -fx-padding: 10; -fx-border-radius: 5;"/>
    </HBox>
</VBox>