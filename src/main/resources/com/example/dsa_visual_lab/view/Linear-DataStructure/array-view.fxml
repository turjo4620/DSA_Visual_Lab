<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dsa_visual_lab.controller.linear.ArrayController"
      stylesheets="@../styles/linear/array.css"
      styleClass="array-root"
      spacing="20">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="← BACK"
                prefWidth="120" prefHeight="40"
                onAction="#onBackClick"
                styleClass="back-button"/>
        <Label text="Dynamic Array Visualization"
               styleClass="title-label"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <VBox spacing="15" HBox.hgrow="ALWAYS" alignment="CENTER">

            <Label fx:id="lblSizeCap"
                   text="Size = 0 | Capacity = 8"
                   styleClass="size-cap-label"/>

            <ScrollPane fitToHeight="true" fitToWidth="true"
                        vbarPolicy="NEVER"
                        styleClass="scroll-pane"
                        VBox.vgrow="ALWAYS">
                <content>
                    <Pane fx:id="visualPane"
                          prefHeight="350" minWidth="800"
                          styleClass="visual-pane"/>
                </content>
            </ScrollPane>

            <Label fx:id="statusLabel"
                   text="System Ready"
                   styleClass="status-label"/>
        </VBox>

        <VBox prefWidth="320" spacing="15" styleClass="analysis-panel">
            <VBox.margin>
                <Insets top="0" right="0" bottom="0" left="0"/>
            </VBox.margin>

            <Label text="Analysis Panel" styleClass="panel-title"/>
            <Pane styleClass="panel-divider"/>

            <Label text="Time Complexity" styleClass="complexity-title"/>
            <Label fx:id="complexityLabel"
                   text="..."
                   wrapText="true"
                   styleClass="complexity-label"/>

            <Pane styleClass="panel-divider"/>

            <Label text="Pseudocode" styleClass="complexity-title"/>
            <VBox fx:id="pseudoCodeBox"
                  styleClass="inner-code-box"
                  VBox.vgrow="ALWAYS"
                  spacing="5">
                <Label text="Code will appear here"
                       styleClass="pseudocode-line"/>
            </VBox>
        </VBox>

    </HBox>

    <VBox fx:id="controlsBox" styleClass="controls-box" spacing="10">

        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="insertValueField"
                       promptText="Value"
                       prefWidth="100"
                       styleClass="text-field"/>
            <TextField fx:id="insertIndexField"
                       promptText="Index"
                       prefWidth="100"
                       styleClass="text-field"/>
            <Button text="Append"
                    onAction="#btnAppend"
                    prefWidth="120"
                    styleClass="btn-insert"/>
            <Button text="Insert at Index"
                    onAction="#btnInsertAtIndex"
                    prefWidth="130"
                    styleClass="btn-insert"/>
            <Button text="Remove Last"
                    onAction="#btnRemoveLast"
                    prefWidth="120"
                    styleClass="btn-remove"/>
            <Button text="Remove at Index"
                    onAction="#btnRemoveAtIndex"
                    prefWidth="140"
                    styleClass="btn-remove"/>
        </HBox>

        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="searchValField"
                       promptText="Search Val"
                       prefWidth="110"
                       styleClass="text-field"/>
            <Button text="Linear Search"
                    onAction="#btnLinearSearch"
                    prefWidth="125"
                    styleClass="btn-action"/>
            <ComboBox fx:id="findTypeCombo"
                      prefWidth="85"
                      styleClass="combo-box-custom"/>
            <Button text="Find"
                    onAction="#btnFindAction"
                    prefWidth="70"
                    styleClass="btn-action"/>

            <Pane prefWidth="10"/>

            <TextField fx:id="capacityField"
                       text="8" promptText="Cap"
                       prefWidth="60"
                       styleClass="text-field"/>
            <TextField fx:id="initValuesField"
                       promptText="e.g. 5, 10, 15"
                       prefWidth="150"
                       styleClass="text-field"/>
            <Button text="Create Array"
                    onAction="#btnCreateArray"
                    prefWidth="125"
                    styleClass="primary-btn"/>

            <VBox styleClass="speed-box">
                <Label text="Speed" styleClass="speed-label"/>
                <Slider fx:id="speedSlider"
                        min="10" max="100" value="50"
                        prefWidth="80"/>
            </VBox>
        </HBox>
    </VBox>

</VBox>