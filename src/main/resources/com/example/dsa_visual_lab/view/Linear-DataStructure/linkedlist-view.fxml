<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dsa_visual_lab.controller.linear.LinkedListController"
      stylesheets="@../styles/linear/linkedlist.css"
      styleClass="linkedlist-root"
      spacing="20">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="← BACK"
                prefWidth="120" prefHeight="40"
                onAction="#onBackClick"
                styleClass="back-button"/>
        <Label text="Singly Linked List Visualization"
               styleClass="title-label"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <VBox spacing="15" HBox.hgrow="ALWAYS" alignment="CENTER">

            <ScrollPane fitToHeight="true" fitToWidth="true"
                        vbarPolicy="NEVER"
                        styleClass="scroll-pane"
                        VBox.vgrow="ALWAYS">
                <content>
                    <Pane fx:id="visualPane"
                          prefHeight="400" minWidth="1000"
                          styleClass="visual-pane"/>
                </content>
            </ScrollPane>

            <Label fx:id="statusLabel"
                   text="System Ready"
                   styleClass="status-label"/>
        </VBox>

        <VBox prefWidth="320" spacing="15" styleClass="analysis-panel">

            <Label text="Analysis Panel" styleClass="panel-title"/>
            <Pane styleClass="panel-divider"/>

            <Label text="Time Complexity" styleClass="complexity-title"/>
            <Label fx:id="complexityLabel"
                   text="Waiting for action..."
                   wrapText="true"
                   styleClass="complexity-label"/>

            <Pane styleClass="panel-divider"/>

            <Label text="Pseudocode" styleClass="complexity-title"/>
            <VBox fx:id="pseudoCodeBox"
                  styleClass="inner-code-box"
                  VBox.vgrow="ALWAYS"
                  spacing="5">
                <Label text="Code will appear here"
                       styleClass="pseudocode-line"/>
            </VBox>

        </VBox>
    </HBox>

    <HBox fx:id="controlsBox" styleClass="controls-bottom">

        <VBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="valueField"
                       promptText="Value"
                       prefWidth="120"
                       styleClass="text-field"/>
            <TextField fx:id="indexField"
                       promptText="Index"
                       prefWidth="120"
                       styleClass="text-field"/>
        </VBox>

        <Pane prefWidth="15"/>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Insert" styleClass="group-label"/>
            <HBox spacing="8">
                <Button text="Head"
                        onAction="#onInsertHead"
                        prefWidth="85"
                        styleClass="btn-insert"/>
                <Button text="Tail"
                        onAction="#onInsertTail"
                        prefWidth="85"
                        styleClass="btn-insert"/>
                <Button text="At Index"
                        onAction="#onInsertIndex"
                        prefWidth="85"
                        styleClass="btn-insert"/>
            </HBox>
        </VBox>

        <Pane prefWidth="15"/>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Delete" styleClass="group-label"/>
            <HBox spacing="8">
                <Button text="Head"
                        onAction="#onDeleteHead"
                        prefWidth="85"
                        styleClass="btn-delete"/>
                <Button text="Tail"
                        onAction="#onDeleteTail"
                        prefWidth="85"
                        styleClass="btn-delete"/>
                <Button text="At Index"
                        onAction="#onDeleteIndex"
                        prefWidth="85"
                        styleClass="btn-delete"/>
            </HBox>
        </VBox>

        <Pane prefWidth="15"/>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Actions" styleClass="group-label"/>
            <HBox spacing="8">
                <Button text="Search"
                        onAction="#onSearch"
                        prefWidth="85"
                        styleClass="btn-action"/>
            </HBox>
        </VBox>

        <Pane prefWidth="15"/>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Initialize" styleClass="group-label"/>
            <HBox spacing="8">
                <TextField fx:id="initValuesField"
                           promptText="e.g. 5, 10, 15"
                           prefWidth="160"
                           styleClass="text-field"/>
                <Button text="Create List"
                        onAction="#onCreateList"
                        prefWidth="105"
                        styleClass="btn-primary"/>
            </HBox>
        </VBox>

    </HBox>

</VBox>