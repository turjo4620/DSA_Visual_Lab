<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="stackContainer" prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #0F172A;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dsa_visual_lab.controller.linear.StackController">

    <top>
        <StackPane alignment="CENTER_LEFT" prefHeight="100.0">
            <padding>
                <Insets left="30" right="30" top="20" bottom="20"/>
            </padding>

            <Button text="← BACK" onAction="#onBackClick"
                    style="-fx-background-color: transparent; -fx-border-color: #A78BFA; -fx-border-radius: 20; -fx-border-width: 2; -fx-text-fill: #A78BFA; -fx-font-weight: bold; -fx-cursor: hand;"
                    StackPane.alignment="TOP_LEFT">
                <font><Font size="14.0"/></font>
                <padding><Insets top="8" right="20" bottom="8" left="20"/></padding>
            </Button>

            <Label text="Stack Visualization (LIFO)" textFill="#A78BFA" StackPane.alignment="CENTER">
                <font>
                    <Font name="System Bold" size="36.0" />
                </font>
                <style>-fx-effect: dropshadow(three-pass-box, rgba(167, 139, 250, 0.4), 15, 0.2, 0, 0);</style>
            </Label>
        </StackPane>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <ScrollPane fx:id="scrollPane" prefHeight="400.0" prefWidth="800.0"
                        fitToWidth="true" fitToHeight="true"
                        style="-fx-background: #1E293B; -fx-background-color: #1E293B; -fx-background-radius: 20; -fx-border-color: #334155; -fx-border-radius: 20; -fx-border-width: 2;">
                <content>
                    <VBox fx:id="visualPane" alignment="BOTTOM_CENTER" spacing="5.0"
                          style="-fx-background-color: transparent;">
                        <padding><Insets bottom="10" top="10"/></padding>
                    </VBox>
                </content>
            </ScrollPane>

            <Label fx:id="statusLabel" text="Ready" textFill="#FCD34D"
                   style="-fx-background-color: #334155; -fx-padding: 10 25; -fx-background-radius: 12; -fx-border-color: #475569; -fx-border-radius: 12;">
                <font><Font name="System Bold" size="20.0"/></font>
            </Label>
        </VBox>
    </center>

    <right>
        <VBox prefWidth="320.0" spacing="15"
              style="-fx-background-color: #1E293B; -fx-background-radius: 20; -fx-border-color: #334155; -fx-border-radius: 20; -fx-border-width: 2;">
            <padding><Insets top="25" right="20" bottom="25" left="20"/></padding>
            <BorderPane.margin><Insets top="20" right="20" bottom="20" left="0"/></BorderPane.margin>

            <Label text="Analysis Panel" textFill="#A78BFA">
                <font><Font name="System Bold" size="22.0"/></font>
            </Label>

            <Pane prefHeight="2" style="-fx-background-color: #334155;" />

            <Label text="Time Complexity" textFill="#60A5FA">
                <font><Font name="System Bold" size="16.0"/></font>
            </Label>
            <Label fx:id="complexityLabel" text="Waiting for action..." textFill="#E2E8F0" wrapText="true">
                <font><Font size="14.0"/></font>
            </Label>

            <Pane prefHeight="2" style="-fx-background-color: #334155;" />

            <Label text="Pseudo-code" textFill="#60A5FA">
                <font><Font name="System Bold" size="16.0"/></font>
            </Label>

            <VBox fx:id="pseudoCodeBox" prefHeight="200.0" spacing="2"
                  style="-fx-background-color: #0F172A; -fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #334155; -fx-border-radius: 8;">
                <Label text="" textFill="#34D399">
                    <font><Font name="Consolas" size="14.0"/></font>
                </Label>
            </VBox>
        </VBox>
    </right>

    <bottom>
        <VBox spacing="15" alignment="CENTER">
            <padding><Insets bottom="60" top="10" right="320"/></padding>

            <HBox fx:id="controlsBox" alignment="CENTER" spacing="20.0">
                <TextField fx:id="inputField" promptText="Value" prefWidth="120" prefHeight="45"
                           style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-border-color: #A78BFA; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px;"/>

                <Button text="Push" onAction="#onPush" prefHeight="45" prefWidth="120"
                        style="-fx-background-color: #A78BFA; -fx-text-fill: #0F172A; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 15px;"/>

                <Button text="Pop" onAction="#onPop" prefHeight="45" prefWidth="120"
                        style="-fx-background-color: transparent; -fx-border-color: #F87171; -fx-text-fill: #F87171; -fx-border-width: 2; -fx-border-radius: 8; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 15px;"/>

                <Pane prefWidth="20" />

                <Button text="Peek" onAction="#onPeek" prefHeight="45" prefWidth="120"
                        style="-fx-background-color: #1E293B; -fx-border-color: #60A5FA; -fx-text-fill: #60A5FA; -fx-border-width: 2; -fx-border-radius: 8; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 15px;"/>

                <Button text="IsEmpty" onAction="#onIsEmpty" prefHeight="45" prefWidth="120"
                        style="-fx-background-color: #1E293B; -fx-border-color: #FCD34D; -fx-text-fill: #FCD34D; -fx-border-width: 2; -fx-border-radius: 8; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 15px;"/>

                <Button text="Clear" onAction="#onClear" prefHeight="45" prefWidth="120"
                        style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 15px;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>