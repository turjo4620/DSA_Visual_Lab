<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="linearContainer" prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #0F172A;"
            stylesheets="@../styles/linear/linear.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dsa_visual_lab.controller.home.LinearDataStructureController">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <top>
        <StackPane alignment="CENTER_LEFT" prefHeight="120.0">
            <padding>
                <Insets top="20" right="40" bottom="20" left="40"/>
            </padding>

            <VBox alignment="CENTER" spacing="10.0"
                  pickOnBounds="false" mouseTransparent="true">
                <Label text="Linear Structures" textFill="#818CF8">
                    <font>
                        <Font name="System Bold" size="48.0"/>
                    </font>
                    <style>
                        -fx-effect: dropshadow(three-pass-box, rgba(129, 140, 248, 0.4), 15, 0.2, 0, 0);
                    </style>
                </Label>
                <Label text="Select a structure to visualize" textFill="#94A3B8">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>
            </VBox>

            <Button text="← BACK"
                    onAction="#onBackClick"
                    StackPane.alignment="TOP_LEFT"
                    prefWidth="120" prefHeight="40"
                    styleClass="back-button">
                <font>
                    <Font size="14.0"/>
                </font>
            </Button>

        </StackPane>
    </top>

    <center>
        <FlowPane alignment="CENTER" hgap="40.0" vgap="40.0">

            <Button fx:id="btnArray"
                    onAction="#onArrayClick"
                    text="Dynamic Array"
                    styleClass="algo-button, btn-array"
                    prefWidth="300.0" prefHeight="180.0">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Button>

            <Button fx:id="btnQueue"
                    onAction="#onQueueClick"
                    text="Queue (FIFO)"
                    styleClass="algo-button, btn-queue"
                    prefWidth="300.0" prefHeight="180.0">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Button>

            <Button fx:id="btnStack"
                    onAction="#onStackClick"
                    text="Stack (LIFO)"
                    styleClass="algo-button, btn-stack"
                    prefWidth="300.0" prefHeight="180.0">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Button>

            <Button fx:id="btnLinkedList"
                    onAction="#onLinkedListClick"
                    text="Singly Linked List"
                    styleClass="algo-button, btn-linkedlist"
                    prefWidth="300.0" prefHeight="180.0">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Button>

        </FlowPane>
    </center>

</BorderPane>