<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dsa_visual_lab.controller.linear.QueueController"
      stylesheets="@../styles/linear/queue.css"
      styleClass="queue-root"
      spacing="20">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="← BACK"
                prefWidth="120" prefHeight="40"
                onAction="#onBackClick"
                styleClass="back-button"/>
        <Label text="Queue Visualization (FIFO)"
               styleClass="title-label"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <VBox spacing="15" HBox.hgrow="ALWAYS" alignment="CENTER">

            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true" fitToHeight="true"
                        vbarPolicy="NEVER"
                        styleClass="scroll-pane"
                        VBox.vgrow="ALWAYS">
                <content>
                    <HBox fx:id="visualPane"
                          alignment="CENTER_LEFT" spacing="10"
                          prefHeight="350" minWidth="1000"
                          styleClass="visual-pane">
                        <padding>
                            <Insets left="20" right="20"/>
                        </padding>
                    </HBox>
                </content>
            </ScrollPane>

            <Label fx:id="statusLabel"
                   text="System Ready"
                   styleClass="status-label"/>
        </VBox>

        <VBox prefWidth="320" spacing="15" styleClass="analysis-panel">

            <Label text="Analysis Panel" styleClass="panel-title"/>
            <Pane styleClass="panel-divider"/>

            <Label text="Time Complexity" styleClass="complexity-title"/>
            <Label fx:id="complexityLabel"
                   text="Waiting for action..."
                   wrapText="true"
                   styleClass="complexity-label"/>

            <Pane styleClass="panel-divider"/>

            <Label text="Pseudocode" styleClass="complexity-title"/>
            <VBox fx:id="pseudoCodeBox"
                  styleClass="inner-code-box"
                  VBox.vgrow="ALWAYS"
                  spacing="5">
                <Label text="Code will appear here"
                       styleClass="pseudocode-line"/>
            </VBox>

        </VBox>
    </HBox>

    <HBox fx:id="controlsBox" styleClass="controls-bottom">

        <TextField fx:id="inputField"
                   promptText="Value"
                   prefWidth="120"
                   styleClass="text-field"/>

        <Pane prefWidth="15"/>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Modify" styleClass="group-label"/>
            <HBox spacing="8">
                <Button text="Enqueue"
                        onAction="#onEnqueue"
                        prefWidth="95"
                        styleClass="btn-enqueue"/>
                <Button text="Dequeue"
                        onAction="#onDequeue"
                        prefWidth="95"
                        styleClass="btn-dequeue"/>
            </HBox>
        </VBox>

        <Pane prefWidth="15"/>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Actions" styleClass="group-label"/>
            <HBox spacing="8">
                <Button text="Peek Front"
                        onAction="#onPeekFront"
                        prefWidth="105"
                        styleClass="btn-action"/>
                <Button text="Peek Back"
                        onAction="#onPeekBack"
                        prefWidth="105"
                        styleClass="btn-action"/>
                <Button text="IsEmpty"
                        onAction="#onIsEmpty"
                        prefWidth="90"
                        styleClass="btn-action"/>
            </HBox>
        </VBox>

        <Pane prefWidth="15"/>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Initialize" styleClass="group-label"/>
            <HBox spacing="8">
                <TextField fx:id="listInputField"
                           promptText="e.g. 10, 20, 30"
                           prefWidth="160"
                           styleClass="text-field"/>
                <Button text="Create Queue"
                        onAction="#onCreateList"
                        prefWidth="125"
                        styleClass="btn-primary"/>
                <Button text="Clear"
                        onAction="#onClear"
                        prefWidth="75"
                        styleClass="btn-clear"/>
            </HBox>
        </VBox>

    </HBox>

</VBox>