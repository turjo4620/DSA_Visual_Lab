<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="800.0" prefWidth="1280.0"
            stylesheets="@../styles/dp/dp.css"
            styleClass="dp-root"
            xmlns="http://javafx.com/javafx/21.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dsa_visual_lab.controller.dp.KnapsackController">

    <top>
        <StackPane alignment="CENTER_LEFT" prefHeight="80.0" styleClass="top-pane">
            <Button onAction="#onBackClick" text="← BACK" prefWidth="120" prefHeight="40" styleClass="back-button" StackPane.alignment="CENTER_LEFT" />
            <Label text="0/1 Knapsack (Dynamic Programming)" styleClass="title-label" StackPane.alignment="CENTER" />
        </StackPane>
    </top>

    <center>
        <HBox spacing="10" styleClass="main-content-box">
            <ScrollPane fx:id="scrollPane" fitToHeight="true" fitToWidth="true" styleClass="dp-scroll-pane" HBox.hgrow="ALWAYS">
                <GridPane fx:id="dpGrid" alignment="CENTER" hgap="5" vgap="5" styleClass="dp-grid" />
            </ScrollPane>

            <VBox prefWidth="350.0" spacing="15" styleClass="side-panel">
                <Label styleClass="section-title-complexity" text="Time &amp; Space Complexity" />
                <Label fx:id="complexityLabel" styleClass="info-box" text="Waiting for action..." wrapText="true" />

                <Label styleClass="section-title-pseudo" text="Pseudocode">
                    <VBox.margin>
                        <Insets top="10" />
                    </VBox.margin>
                </Label>
                <VBox fx:id="pseudoCodeBox" spacing="2" styleClass="pseudo-container" VBox.vgrow="ALWAYS" />
            </VBox>
        </HBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="15" styleClass="bottom-panel">
            <Label fx:id="statusLabel" styleClass="status-label" text="Ready" />

            <HBox fx:id="controlsBox" alignment="BOTTOM_CENTER" spacing="15">

                <VBox alignment="CENTER" spacing="5" styleClass="speed-box">
                    <Label styleClass="speed-label" text="Speed" />
                    <Slider fx:id="speedSlider" max="200" min="10" prefWidth="100" value="100" />
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label text="Capacity (W)" styleClass="input-label" />
                    <TextField fx:id="capacityField" prefWidth="100" promptText="e.g. 5" styleClass="input-field" />
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label text="Weights" styleClass="input-label" />
                    <TextField fx:id="weightsField" prefWidth="150" promptText="e.g. 1, 3, 4" styleClass="input-field" />
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label text="Values" styleClass="input-label" />
                    <TextField fx:id="valuesField" prefWidth="150" promptText="e.g. 15, 20, 30" styleClass="input-field" />
                </VBox>

                <HBox alignment="BOTTOM_CENTER" spacing="10">
                    <Button onAction="#onSolve" prefWidth="90" styleClass="solve-btn" text="Solve" />
                    <Button onAction="#onClear" prefWidth="70" styleClass="clear-btn" text="Clear" />
                </HBox>

            </HBox>
        </VBox>
    </bottom>
</BorderPane>