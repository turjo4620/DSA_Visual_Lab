<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainContainer" prefHeight="650.0" prefWidth="1000.0"
            stylesheets="@../styles/home.css"
            styleClass="main-container"
            xmlns="http://javafx.com/javafx/21.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dsa_visual_lab.controller.home.HomeController">

    <top>
        <StackPane prefHeight="200.0" styleClass="header-pane">
            <VBox alignment="CENTER" spacing="10.0">
                <Label text="DSA VISUAL LAB" styleClass="title-label" />
                <Label text="Master Data Structures &amp; Algorithms Through Visualization" styleClass="subtitle-label" />
            </VBox>
        </StackPane>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll-pane">
            <content>
                <FlowPane alignment="CENTER" hgap="30.0" vgap="30.0" prefWrapLength="950.0">
                    <padding>
                        <Insets top="40.0" bottom="40.0" left="20.0" right="20.0" />
                    </padding>

                    <Button onAction="#openSorting" prefHeight="150.0" prefWidth="280.0"
                            text="SORTING&#10;ALGORITHMS" textAlignment="CENTER"
                            styleClass="algo-button" id="sorting-btn" />

                    <Button onAction="#openDataStructures" prefHeight="150.0" prefWidth="280.0"
                            text="LINEAR&#10;STRUCTURES" textAlignment="CENTER"
                            styleClass="algo-button" id="linear-btn" />

                    <Button onAction="#openTrees" prefHeight="150.0" prefWidth="280.0"
                            text="BINARY SEARCH&#10;TREE" textAlignment="CENTER"
                            styleClass="algo-button" id="tree-btn" />

                    <Button onAction="#openGraphs" prefHeight="150.0" prefWidth="280.0"
                            text="GRAPH&#10;THEORY" textAlignment="CENTER"
                            styleClass="algo-button" id="graph-btn" />

                    <Button onAction="#openMST" prefHeight="150.0" prefWidth="280.0"
                            text="GREEDY &amp;&#10;MST" textAlignment="CENTER"
                            styleClass="algo-button" id="mst-btn" />

                    <Button onAction="#openDP" prefHeight="150.0" prefWidth="280.0"
                            text="DYNAMIC&#10;PROGRAMMING" textAlignment="CENTER"
                            styleClass="algo-button" id="dp-btn" />
                </FlowPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>